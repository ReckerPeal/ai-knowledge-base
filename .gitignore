# macOS
.DS_Store
.AppleDouble
.LSOverride

# Python bytecode and caches
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
.pyre/
.coverage
coverage.xml
htmlcov/

# Virtual environments
.venv/
venv/
env/
ENV/

# Build and packaging
build/
dist/
*.egg-info/
.eggs/

# Environment and secrets
.env
.env.*
!.env.example
*.pem
*.key
*.crt

# Logs and runtime files
*.log
logs/
tmp/
temp/
.cache/

# IDEs and editors
.idea/
.vscode/
*.swp
*.swo
*~

# OpenCode local state
.codex/cache/
.codex/tmp/
.codex/logs/
.opencode/cache/
.opencode/tmp/
.opencode/logs/

# Project generated data
knowledge/raw/*
knowledge/articles/*
!knowledge/raw/.gitkeep
!knowledge/articles/.gitkeep
